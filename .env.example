# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# Encontrás estos valores en R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=sessions-poc
# Opcional: se construye automáticamente como https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT=

# ─── Firebase ─────────────────────────────────────────────────────────────────
# Opción A (desarrollo local): ruta al archivo JSON de service account
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Opción B (producción / Railway / Render): contenido del JSON en base64
# Generalo con: base64 -w 0 firebase-credentials.json
# FIREBASE_CREDENTIALS_B64=

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
CHUNK_DURATION_SECONDS=30